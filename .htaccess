<IfModule mod_rewrite.c>
  # Enable rewrite engine
  RewriteEngine On
  RewriteBase /
  
  # Presmerovanie HTTP → HTTPS (SSL/TLS)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Podávaj WebP obrázky namiesto PNG/JPG, ak je podporovaný
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteCond %{REQUEST_FILENAME} ^(.+)\.(png|jpg|jpeg)$
  RewriteRule ^(.+)\.(png|jpg|jpeg)$ %{REQUEST_FILENAME}.webp [QSA,T=image/webp,L]
</IfModule>

# Vypni zoznam súborov v zložkách (Directory Listing)
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

<IfModule mod_headers.c>
  # ============================================
  # BEZPEČNOSTNÉ HEADERY (Security Headers)
  # ============================================
  
  # HSTS - Nútenie HTTPS na 1 rok (31536000 sekúnd)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  
  # Zákaz framing (clickjacking ochrana)
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Zabrániť MIME sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # XSS ochrana
  Header set X-XSS-Protection "1; mode=block"
  
  # Referrer politika - odošli len minimálne info
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Permissions Policy - vypni nebezpečné API
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
  
  # Content Security Policy - povolenie iba svojich resursov
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' formspree.io www.googletagmanager.com www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' formspree.io www.google-analytics.com; frame-ancestors 'self'"
  
  # ============================================
  # CACHE CONTROL HEADERY
  # ============================================
  
  # HTML - cache 1 deň
  <FilesMatch "\.html?$">
    Header set Cache-Control "max-age=86400, must-revalidate"
  </FilesMatch>

  # CSS, JS - cache 30 dní
  <FilesMatch "\.(css|js|webp)$">
    Header set Cache-Control "max-age=2592000, public, immutable"
  </FilesMatch>

  # Obrázky - cache 1 rok
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # Fonts - cache 1 rok
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # Nastav Content-Type pre WebP
  <FilesMatch "\.webp$">
    Header set Content-Type "image/webp"
  </FilesMatch>

  # AddType pre WebP
  Add Type image/webp .webp
</IfModule>

<IfModule mod_deflate.c>
  # Enable GZIP kompresiu
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE application/x-font-otf
  AddOutputFilterByType DEFLATE application/x-font-woff
  AddOutputFilterByType DEFLATE application/x-font-woff2
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE image/svg+xml
  
  # Remove pragma header
  Header append Vary Accept-Encoding
</IfModule>

# Pre servery bez mod_deflate
<IfModule mod_gzip.c>
  mod_gzip_on Yes
  mod_gzip_dechunk Yes
  mod_gzip_item_include file \.(html?|txt|css|js|json|xml|svg|ttf|otf|woff|woff2)$
  mod_gzip_item_include handler ^cgi-script$
  mod_gzip_item_exclude mime ^image/
  mod_gzip_item_exclude rn ^/, /^(
  mod_gzip_minimum_file_size 1000
  mod_gzip_maximum_file_size 0
  mod_gzip_maximum_inmemory_size 1048576
</IfModule>
